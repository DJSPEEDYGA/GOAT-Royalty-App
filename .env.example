# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/royalty-app

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=30d

# Email Configuration (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
FROM_EMAIL=noreply@goatroyalty.com
FROM_NAME=GOAT Royalty App

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CLIENT_URL=http://localhost:3000

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-change-this

# Payment Processing (Optional)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Third-party Integrations
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

APPLE_MUSIC_API_KEY=your-apple-music-api-key

YOUTUBE_API_KEY=your-youtube-api-key

# Monitoring (Optional)
SENTRY_DSN=your-sentry-dsn

# Analytics (Optional)
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX

# AI Agent Configuration
OPENAI_API_KEY=sk-your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
COHERE_API_KEY=your-cohere-api-key

# Agent Settings
AGENT_MODEL=gpt-4-turbo-preview
AGENT_TEMPERATURE=0.7
AGENT_MAX_ITERATIONS=10

# Hostinger API Configuration
HOSTINGER_API_TOKEN=your-hostinger-api-token-here

# ── Loyalty Keys (GOAT Royalty Force member identity tokens) ──────────────────
# These should be long, high-entropy strings. Do NOT use placeholder values.
LOYALTY_KEY_HARVEY=
LOYALTY_KEY_MONEYPENNY=
LOYALTY_KEY_WAKA=
LOYALTY_KEY_CODEX=
LOYALTY_KEY_MSVANESSA=
LOYALTY_KEY_APEX=

# ── Loyalty AES-256-GCM encryption key (64 hex chars = 32 bytes) ─────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LOYALTY_ENCRYPTION_SECRET=

# ── Activation ────────────────────────────────────────────────────────────────
# SHA-256 hash of the master activation code.
# Generate: node -e "console.log(require('crypto').createHash('sha256').update('YOUR_CODE').digest('hex'))"
ACTIVATION_HASH=

# ── TOTP / MFA ────────────────────────────────────────────────────────────────
# Base32-encoded TOTP secret (scan QR code with authenticator app).
# Generate: node -e "const {authenticator}=require('otplib'); console.log(authenticator.generateSecret())"
TOTP_SECRET=

# ── Offline Recovery Key ──────────────────────────────────────────────────────
# SHA-256 hash of the offline recovery key held by Harvey/Apex offline.
# Generate: node -e "console.log(require('crypto').createHash('sha256').update('YOUR_OFFLINE_KEY').digest('hex'))"
RECOVERY_OFFLINE_KEY=

# ── IP Whitelisting ───────────────────────────────────────────────────────────
# Comma-separated IPs allowed on sensitive endpoints. Leave empty to disable.
WHITELISTED_IPS=

# ── Intrusion Detection / Lockout ─────────────────────────────────────────────
LOCKOUT_THRESHOLD=10
LOCKOUT_DURATION_MS=900000

# ── Sensitive Endpoint Rate Limit ─────────────────────────────────────────────
SENSITIVE_RATE_LIMIT=20