# ==========================================
# SUPER GOAT ROYALTIES - Configuration
# ==========================================
# Copy this file to .env and fill in your keys.
# The app works 100% offline without any keys.

# ---- Demo / Live Mode ----
DEMO_MODE=false

# ---- Server Configuration ----
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# ---- Security ----
# Use long random strings in production (e.g. openssl rand -hex 32)
JWT_SECRET=
ENCRYPTION_KEY=

# ---- Owner Secret (required for casino/gaming/real-money toggles) ----
GOAT_OWNER_SECRET=

# ---- Model Pool Paths (comma-separated; can be Agent-007, Money Penny, or shared pools) ----
# Example: /Volumes/i2i 1/Agent-007-Models,/Volumes/i2i 1/Money-Penny-Models,/Volumes/i2i 1/Agent-007-GOAT/Shared/models
GOAT_MODEL_PATHS=

# ---- NVIDIA NIM (Primary AI Engine) ----
# Get your key at: https://build.nvidia.com
NVIDIA_API_KEY=
NVIDIA_NIM_URL=https://integrate.api.nvidia.com/v1

# ---- Google AI Studio (Optional) ----
# Get your key at: https://aistudio.google.com
GOOGLE_AI_STUDIO_KEY=

# ---- OpenAI (Optional, for LangChain) ----
OPENAI_API_KEY=

# ---- Database (Optional - Supabase) ----
SUPABASE_URL=
SUPABASE_KEY=

# ---- Embedded Service Keys (Optional) ----
SUPER_NINJA_API_KEY=
HOSTINGER_API_KEY=
FASHION_APP_API_KEY=

# ---- Server Metadata ----
SERVER_IP=
SERVER_OS=
SERVER_CPU=
SERVER_RAM=
SERVER_DISK=
SERVER_LOCATION=

# ---- Platform API Keys (Optional) ----
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
YOUTUBE_API_KEY=

# ---- Webhooks (Optional) ----
WEBHOOK_SECRET=
