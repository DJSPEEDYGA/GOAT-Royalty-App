{
  "name": "goat-royalty-app",
  "version": "1.0.0",
  "description": "GOAT-Royalty-App is a comprehensive royalty management application for tracking payments and distributions for artists and content creators.",
  "main": "app/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently &quot;npm run dev:web&quot; &quot;npm run dev:electron&quot;",
    "dev:web": "node src/server.js",
    "dev:electron": "wait-on http://localhost:3000 && electron .",
    "dev:legacy": "concurrently &quot;npm run server&quot; &quot;npm run client&quot;",
    "server": "nodemon src/server.js",
    "client": "cd client && npm start",
    "build": "npm run build:web && npm run build:electron",
    "build:web": "cd client && npm run build",
    "build:electron": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "pipeline": "node scripts/google-drive-pipeline.js",
    "setup-pipeline": "bash scripts/setup-google-drive-pipeline.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DJSPEEDYGA/GOAT-Royalty-App.git"
  },
  "keywords": [
    "royalty",
    "management",
    "payments",
    "artists",
    "content-creators",
    "distribution"
  ],
  "author": "DJSPEEDYGA",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/DJSPEEDYGA/GOAT-Royalty-App/issues"
  },
  "homepage": "https://github.com/DJSPEEDYGA/GOAT-Royalty-App#readme",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@langchain/anthropic": "^1.2.0",
    "@langchain/openai": "^1.1.3",
    "anthropic": "^0.0.0",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "chokidar": "^3.5.3",
    "cohere": "^1.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "fluent-ffmpeg": "^2.1.2",
    "googleapis": "^173.0.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^1.1.2",
    "langsmith": "^0.7.14",
    "mongoose": "^9.0.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "music-metadata": "^11.13.0",
    "node-cron": "^4.5.0",
    "nodemailer": "^9.0.3",
    "openai": "^6.9.1",
    "otplib": "^13.3.0",
    "pdf-parse": "^1.1.1",
    "replicate": "^1.4.0",
    "sharp": "^0.34.5",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^43.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.7.3",
    "supertest": "^7.1.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.goatforce.royaltyapp",
    "productName": "GOAT Royalty App",
    "copyright": "Copyright © 2025 DJSPEEDYGA · GOAT FORCE",
    "directories": {
      "output": "dist-electron",
      "buildResources": "assets"
    },
    "files": [
      "app/**/*",
      "web-app/**/*",
      "goat-intel-server/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      { "from": "web-app", "to": "web-app" },
      { "from": "goat-intel-server", "to": "goat-intel-server" },
      { "from": "assets", "to": "assets" }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64", "arm64"] },
        { "target": "zip",  "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico",
      "publisherName": "GOAT FORCE",
      "verifyUpdateCodeSignature": false
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["arm64"] }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.music",
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb",      "arch": ["x64"] },
        { "target": "rpm",      "arch": ["x64"] }
      ],
      "icon": "assets/icon.png",
      "category": "Audio;Music;AudioVideo",
      "synopsis": "GOAT Royalty App — Music Production & AI Command Center",
      "description": "Professional music production suite with AI-powered beat making, mixing, mastering, royalty tracking and more."
    },
    "dmg": {
      "title": "GOAT Royalty App",
      "backgroundColor": "#060608",
      "window": { "width": 660, "height": 400 },
      "contents": [
        { "x": 180, "y": 170, "type": "file" },
        { "x": 480, "y": 170, "type": "link", "path": "/Applications" }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GOAT Royalty App",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "deb": {
      "depends": ["python3", "python3-pip"]
    }
  }
}
