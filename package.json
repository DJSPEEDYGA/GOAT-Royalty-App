{
  "name": "super-goat-royalties",
  "version": "5.1.0",
  "description": "SUPER GOAT Royalties - Ultimate AI-Powered Creator Platform with NVIDIA NIM, LangChain, RAG & Autonomous Agents",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "start:web": "NODE_ENV=production node server.js",
    "dev": "nodemon server.js",
    "electron": "electron .",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:build": "electron-builder --publish never",
    "electron:build:win": "electron-builder --win --publish never",
    "electron:build:mac": "electron-builder --mac --publish never",
    "electron:build:linux": "electron-builder --linux --publish never",
    "electron:build:all": "electron-builder --win --mac --linux",
    "test": "jest",
    "vercel-build": "echo 'No build step required for Express server'"
  },
  "keywords": [
    "super-goat-royalties",
    "ai",
    "llm",
    "nvidia",
    "nemo",
    "langchain",
    "rag",
    "autonomous-agents",
    "creator-platform",
    "royalties",
    "nft",
    "blockchain",
    "electron",
    "desktop-app"
  ],
  "author": {
    "name": "DJSPEEDYGA",
    "email": "djspeedyga@lifeimitatesart.org"
  },
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.1.3",
    "@langchain/community": "^1.1.24",
    "@langchain/core": "^1.1.35",
    "@langchain/openai": "^1.3.0",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.0.0-rc.12",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^1.2.36",
    "mammoth": "^1.6.0",
    "morgan": "^1.10.0",
    "node-cache": "^5.1.2",
    "openai": "^4.28.0",
    "pdf-parse": "^1.1.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^24.9.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "build": {
    "appId": "com.goatroyalties.superapp",
    "productName": "SUPER GOAT Royalties",
    "copyright": "Copyright © 2024 DJSPEEDYGA",
    "directories": {
      "output": "dist"
    },
    "files": [
      "server.js",
      "electron-main.js",
      "preload.js",
      "public/**/*",
      "lib/**/*",
      "data/**/*",
      "node_modules/**/*",
      "package.json",
      "favicon.ico"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "SUPER-GOAT-ROYALTIES-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "SUPER-GOAT-ROYALTIES-Portable-${version}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "artifactName": "SUPER-GOAT-ROYALTIES-${version}-${arch}.${ext}",
      "category": "public.app-category.music"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "artifactName": "SUPER-GOAT-ROYALTIES-${version}-${arch}.${ext}",
      "category": "Audio"
    }
  }
}
