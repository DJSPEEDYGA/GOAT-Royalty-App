# ============================================================
# GOAT ROYALTY APP — API KEYS (.env.example)
# ============================================================
# COPY this file to `.env` on your production server and fill in real values.
# NEVER commit `.env` — add to .gitignore!
# ============================================================

# ---------- SERVER ----------
PORT=3001
NODE_ENV=production
CORS_ORIGIN=https://goatroyalty.app

# ---------- TIKTOK FOR DEVELOPERS ----------
# Register at: https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://goatroyalty.app/tiktok/callback
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=

# ---------- DISTROKID ----------
# Partner API: contact [email protected]
# OR: extract bearer from iOS app (personal use only)
DISTROKID_EMAIL=
DISTROKID_BEARER_TOKEN=
DISTROKID_API_KEY=
DISTROKID_USER_ID=

# ---------- SPOTIFY FOR DEVELOPERS ----------
# https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=https://goatroyalty.app/spotify/callback
SPOTIFY_ARTIST_ID=

# ---------- APPLE MUSIC FOR ARTISTS ----------
# https://developer.apple.com/
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
# (Paste content of .p8 file between BEGIN/END markers)

# ---------- YOUTUBE DATA API ----------
# https://console.cloud.google.com/
YOUTUBE_API_KEY=
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=https://goatroyalty.app/youtube/callback
YOUTUBE_CHANNEL_ID=

# ---------- STRIPE (PAYMENTS) ----------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ---------- DATABASE ----------
DATABASE_URL=postgresql://user:pass@localhost:5432/goat_royalty
REDIS_URL=redis://localhost:6379

# ---------- EMAIL (NOTIFICATIONS) ----------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
[email protected]
SMTP_PASS=
[email protected]

# ---------- AWS S3 (MEDIA STORAGE) ----------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=goat-royalty-media
AWS_REGION=us-east-1

# ---------- JWT / SESSION ----------
JWT_SECRET=
SESSION_SECRET=